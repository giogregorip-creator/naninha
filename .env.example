# Variaveis de ambiente — configure no painel do Railway

# Fornecida automaticamente pelo Railway ao adicionar PostgreSQL
DATABASE_URL=postgresql://usuario:senha@host:5432/railway

# Chave da API Anthropic (para relatorios semanais)
ANTHROPIC_API_KEY=sk-ant-...

# Segredo JWT — gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=string-aleatoria-de-32-chars

# Porta — Railway define automaticamente
PORT=3000

# Dominio do frontend (para CORS)
FRONTEND_URL=https://naninha.app

# Ambiente
NODE_ENV=production
